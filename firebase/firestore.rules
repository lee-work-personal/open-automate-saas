rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getProject(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId));
    }

    function getOrganization(organizationId) {
      return get(/databases/$(database)/documents/organizations/$(organizationId));
    }

    function isOrganizationMember(organizationId) {
      let organization = getOrganization(organizationId);
      return organization.data.ownerId == request.auth.uid ||
             request.auth.uid in organization.data.members;
    }

    function isOrganizationOwner(organizationId) {
      let organization = getOrganization(organizationId);
      return organization.data.ownerId == request.auth.uid;
    }

    function isProjectMember(projectId) {
      let project = getProject(projectId);
      return isOrganizationMember(project.data.organizationId) &&
             (project.data.ownerId == request.auth.uid ||
              request.auth.uid in project.data.members);
    }

    function isProjectOwner(projectId) {
      let project = getProject(projectId);
      return isOrganizationMember(project.data.organizationId) &&
             project.data.ownerId == request.auth.uid;
    }

    function projectMatchesOrganization(projectId, organizationId) {
      let project = getProject(projectId);
      return project.data.organizationId == organizationId;
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read their own document
      allow read: if isAuthenticated() && isOwner(userId);
      // Users can create their own document
      allow create: if isAuthenticated() && isOwner(userId);
      // Users can update their own document
      allow update: if isAuthenticated() && isOwner(userId);
      // Users cannot delete their document (soft delete only)
      allow delete: if false;
    }

    match /organizations/{organizationId} {
      allow read: if isAuthenticated() && isOrganizationMember(organizationId);
      allow create: if isAuthenticated() &&
                       request.resource.data.ownerId == request.auth.uid &&
                       request.auth.uid in request.resource.data.members;
      allow update: if isAuthenticated() &&
                       resource.data.ownerId == request.auth.uid;
      allow delete: if false;
    }
    
    // Projects collection
    match /projects/{projectId} {
      // Owner or members can read - check directly from resource data
      allow read: if isAuthenticated() && 
                     isOrganizationMember(resource.data.organizationId) &&
                     (resource.data.ownerId == request.auth.uid || 
                      request.auth.uid in resource.data.members);
      // Any authenticated user can create a project
      allow create: if isAuthenticated() && 
                       request.resource.data.ownerId == request.auth.uid &&
                       isOrganizationMember(request.resource.data.organizationId);
      // Only owner can update
      allow update: if isAuthenticated() && 
                       resource.data.ownerId == request.auth.uid &&
                       isOrganizationMember(resource.data.organizationId) &&
                       request.resource.data.organizationId == resource.data.organizationId;
      // Only owner can delete
      allow delete: if isAuthenticated() && 
                       resource.data.ownerId == request.auth.uid &&
                       isOrganizationMember(resource.data.organizationId);
    }
    
    // Test Suites collection
    match /testSuites/{suiteId} {
      // Project members can read
      allow read: if isAuthenticated() && 
                     isProjectMember(resource.data.projectId);
      // Only owners can create
      allow create: if isAuthenticated() && 
                       isProjectOwner(request.resource.data.projectId) &&
                       projectMatchesOrganization(request.resource.data.projectId, request.resource.data.organizationId);
      // Only owners can update
      allow update: if isAuthenticated() && 
                       isProjectOwner(resource.data.projectId) &&
                       resource.data.organizationId == request.resource.data.organizationId;
      // Only owners can delete
      allow delete: if isAuthenticated() && 
                       isProjectOwner(resource.data.projectId);
    }
    
    // Test Cases collection
    match /testCases/{testCaseId} {
      // Project members can read
      allow read: if isAuthenticated() && 
                     isProjectMember(resource.data.projectId);
      // Only owners can create
      allow create: if isAuthenticated() && 
                       isProjectOwner(request.resource.data.projectId) &&
                       projectMatchesOrganization(request.resource.data.projectId, request.resource.data.organizationId);
      // Only owners can update
      allow update: if isAuthenticated() && 
                       isProjectOwner(resource.data.projectId) &&
                       resource.data.organizationId == request.resource.data.organizationId;
      // Only owners can delete
      allow delete: if isAuthenticated() && 
                       isProjectOwner(resource.data.projectId);
    }
    
    // Test Runs collection
    match /testRuns/{runId} {
      // Project members can read
      allow read: if isAuthenticated() && 
                     (isProjectMember(resource.data.projectId) || resource.data.triggeredBy == request.auth.uid);
      // Only owners can queue runs
      allow create: if isAuthenticated() && 
                       isProjectOwner(request.resource.data.projectId) &&
                       projectMatchesOrganization(request.resource.data.projectId, request.resource.data.organizationId);
      // Run updates are server-managed
      allow update: if false;
      // No one can delete runs (keep for audit)
      allow delete: if false;
    }
    
    // Test Results collection
    match /testResults/{resultId} {
      // Project members can read
      allow read: if isAuthenticated() && 
                     isProjectMember(resource.data.projectId);
      // Client writes are not allowed in production mode
      allow create: if false;
      // Results are immutable
      allow update: if false;
      // No one can delete results
      allow delete: if false;
    }
    
    // Features collection
    match /features/{featureId} {
      // Project members can read
      allow read: if isAuthenticated() && 
                     isProjectMember(resource.data.projectId);
      // Only owners can create
      allow create: if isAuthenticated() && 
                       isProjectOwner(request.resource.data.projectId) &&
                       projectMatchesOrganization(request.resource.data.projectId, request.resource.data.organizationId);
      // Only owners can update
      allow update: if isAuthenticated() && 
                       isProjectOwner(resource.data.projectId) &&
                       resource.data.organizationId == request.resource.data.organizationId;
      // Only owners can delete
      allow delete: if isAuthenticated() && 
                       isProjectOwner(resource.data.projectId);
    }
    // Variables collection
    match /variables/{variableId} {
      allow read: if isAuthenticated() && isProjectMember(resource.data.projectId);
      allow create: if isAuthenticated() &&
                       isProjectOwner(request.resource.data.projectId) &&
                       projectMatchesOrganization(request.resource.data.projectId, request.resource.data.organizationId);
      allow update: if isAuthenticated() &&
                       isProjectOwner(resource.data.projectId) &&
                       resource.data.organizationId == request.resource.data.organizationId;
      allow delete: if isAuthenticated() && isProjectOwner(resource.data.projectId);
    }
  }
}
