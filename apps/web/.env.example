# Firebase web app configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK service account JSON
# Paste the full JSON as a single line string.
FIREBASE_SERVICE_ACCOUNT_KEY=

# Optional AI provider key
GEMINI_API_KEY=

# Optional worker settings
OPENAUTOMATE_WORKER_CONCURRENCY=1

# Optional SaaS admin emails for the hosted multi-tenant deployment
OPENAUTOMATE_SAAS_ADMIN_EMAILS=
NEXT_PUBLIC_OPENAUTOMATE_SAAS_ADMIN_EMAILS=

# Optional emulator toggle for local development
NEXT_PUBLIC_USE_EMULATORS=false
